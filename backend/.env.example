# =============================================================================
# PrecisionRAG Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual API keys.

# --- Gemini (Google AI) ---
# Used for text-embedding-004 and gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# --- Cohere ---
# Used for Cohere Rerank v3
COHERE_API_KEY=your_cohere_api_key_here

# --- Qdrant ---
# For local disk storage, leave QDRANT_URL empty (uses ./qdrant_data/)
# For Qdrant Cloud, set the URL and API key below
QDRANT_URL=
QDRANT_API_KEY=

# --- Application ---
UPLOAD_DIR=./uploads
QDRANT_DATA_DIR=./qdrant_data
COLLECTION_NAME=precision_rag
BM25_INDEX_PATH=./bm25_index.pkl
METADATA_STORE_PATH=./metadata_store.json
